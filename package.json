{
  "name": "wise2-enterprise",
  "version": "0.1.0",
  "description": "WISE² Enterprise - AI-powered business operating system",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test -- --passWithNoTests",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "migration:run": "npm --prefix packages/api run migration:run",
    "migration:revert": "npm --prefix packages/api run migration:revert"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "pnpm": "^8.15.9",
    "turbo": "^1.10.16"
  },
  "pnpm": {
    "overrides": {
      "typescript": "^5.3.0"
    }
  }
}
