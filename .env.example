# Wise² Core Environment Variables Template
# Copy this file to .env and fill in the actual values
# IMPORTANT: Never commit .env file to Git

# ============================================================================
# Application Settings
# ============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# Application port
APP_PORT=3000

# Node environment
NODE_ENV=development

# ============================================================================
# Database Configuration
# ============================================================================

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_NAME=wise2_core
DB_USER=postgres
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD_HERE
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_SECURE_PASSWORD_HERE
REDIS_DB=0

# ============================================================================
# API Keys & Credentials
# ============================================================================

# Claude API
CLAUDE_API_KEY=CHANGE_ME_YOUR_CLAUDE_API_KEY

# GitHub
GITHUB_TOKEN=CHANGE_ME_YOUR_GITHUB_TOKEN
GITHUB_OWNER=dwise03-bit
GITHUB_REPO=wise2-core

# Ollama (Local LLM)
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama2:latest

# 3D Printer APIs
BAMBU_LAB_API_KEY=CHANGE_ME_YOUR_BAMBU_LAB_KEY
BAMBU_LAB_USERNAME=CHANGE_ME_YOUR_BAMBU_USERNAME
PRUSA_API_KEY=CHANGE_ME_YOUR_PRUSA_API_KEY

# ============================================================================
# Security & Authentication
# ============================================================================

# JWT Secret (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=CHANGE_ME_GENERATE_SECURE_SECRET
JWT_EXPIRATION=24h

# Session Secret
SESSION_SECRET=CHANGE_ME_GENERATE_SECURE_SECRET

# CORS Settings
CORS_ORIGIN=http://localhost:3000

# ============================================================================
# Monitoring & Logging
# ============================================================================

# Logging level: debug, info, warn, error
LOG_LEVEL=info

# Prometheus metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ============================================================================
# Raspberry Pi Settings
# ============================================================================

# Pi hostname
RPI_HOSTNAME=wise2-core-node

# Network interface (eth0 for ethernet, wlan0 for wifi)
RPI_NETWORK_INTERFACE=eth0

# CPU & Memory constraints (for Docker containers)
RPI_CPU_LIMIT=1.5
RPI_MEMORY_LIMIT=512m

# ============================================================================
# Backup & Storage
# ============================================================================

# Backup directory (must exist)
BACKUP_DIR=/var/backups/wise2-core

# Backup schedule (cron format)
BACKUP_SCHEDULE=0 2 * * *

# Backup retention (days)
BACKUP_RETENTION_DAYS=30

# ============================================================================
# External Services (if using cloud infrastructure)
# ============================================================================

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=CHANGE_ME_YOUR_AWS_KEY
AWS_SECRET_ACCESS_KEY=CHANGE_ME_YOUR_AWS_SECRET

# S3 Bucket (for file storage)
S3_BUCKET=wise2-core-data
S3_REGION=us-east-1

# ============================================================================
# Feature Flags
# ============================================================================

# Enable/disable features
FEATURE_AI_AUTOMATION=true
FEATURE_HARDWARE_INTEGRATION=true
FEATURE_CLOUD_SYNC=false
FEATURE_EXPERIMENTAL_UI=false

# ============================================================================
# Development Settings (LOCAL DEVELOPMENT ONLY)
# ============================================================================

# Enable debug mode
DEBUG=wise2:*

# Hot reload
HOT_RELOAD=true

# Mock external services
MOCK_CLAUDE_API=false
MOCK_GITHUB=false

# ============================================================================
# Notification Settings
# ============================================================================

# Email (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=CHANGE_ME_YOUR_EMAIL
EMAIL_PASSWORD=CHANGE_ME_YOUR_EMAIL_PASSWORD
EMAIL_FROM=wise2@example.com

# Email Service (Resend)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_EMAIL=noreply@wisedefense.com

# SMS (if applicable)
TWILIO_ACCOUNT_SID=CHANGE_ME_YOUR_TWILIO_SID
TWILIO_AUTH_TOKEN=CHANGE_ME_YOUR_TWILIO_TOKEN
TWILIO_PHONE_NUMBER=+1234567890

# ============================================================================
# Discord Integration
# ============================================================================

DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_server_id
DISCORD_CHANNEL_ANNOUNCEMENTS=channel_id
DISCORD_CHANNEL_TIPS=channel_id
DISCORD_CHANNEL_GENERAL=channel_id
DISCORD_NEWS_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_BREAKING_NEWS_WEBHOOK_URL=https://discord.com/api/webhooks/...
DISCORD_APPROVAL_CHANNEL_ID=channel_id
DISCORD_2A_ROLE_ID=role_id
DISCORD_ALERT_ROLE_ID=role_id
DISCORD_BREAKING_NEWS_ROLE_ID=role_id

# ============================================================================
# Telegram Integration
# ============================================================================

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHANNEL_ID=channel_id

# ============================================================================
# Social Media APIs
# ============================================================================

TWITTER_API_KEY=your_key
TWITTER_API_SECRET=your_secret
TWITTER_ACCESS_TOKEN=your_token
TWITTER_ACCESS_TOKEN_SECRET=your_secret

INSTAGRAM_ACCESS_TOKEN=your_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=account_id

LINKEDIN_ACCESS_TOKEN=your_token
LINKEDIN_ORG_ID=org_id

# ============================================================================
# News & Content APIs
# ============================================================================

NEWS_API_KEY=your_news_api_key

# ============================================================================
# YouTube & Video Generation
# ============================================================================

YOUTUBE_API_KEY=your_youtube_api_key
YOUTUBE_CHANNEL_ID=your_channel_id
TTS_SERVICE=google

# ============================================================================
# Misc Settings
# ============================================================================

# Timezone
TZ=America/New_York

# Locale
LOCALE=en_US.UTF-8

# ============================================================================
# IMPORTANT SECURITY REMINDERS
# ============================================================================
# 1. NEVER commit .env to Git
# 2. Use strong, random passwords for all services
# 3. Rotate API keys regularly
# 4. Use different secrets for each environment
# 5. Restrict .env file permissions: chmod 600 .env
# 6. Store production secrets in secure vault
# ============================================================================
