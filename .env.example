# Wise² Environment Configuration Template
# Copy this file to .env and customize for your environment
# IMPORTANT: Never commit .env file to Git (add to .gitignore)

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================
NODE_ENV=development
NODE_OPTIONS=--max-old-space-size=512

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL Connection
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wise2_core
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=wise2_core

# Database Logging (development)
DATABASE_DEBUG=false
DATABASE_LOG_LEVEL=debug

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL=redis://:redis-dev@localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis-dev
REDIS_DB=0
REDIS_KEY_PREFIX=wise2:

# ============================================================================
# API SERVICE
# ============================================================================
API_PORT=3000
API_HOST=0.0.0.0
API_LOG_LEVEL=debug
API_CORS_ORIGIN=http://localhost:3001,http://localhost:3002

# ============================================================================
# DASHBOARD SERVICE
# ============================================================================
DASHBOARD_PORT=3001
DASHBOARD_HOST=0.0.0.0
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_LOG_LEVEL=debug

# ============================================================================
# ADMIN DASHBOARD
# ============================================================================
ADMIN_PORT=3002
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:3000

# ============================================================================
# WORKER SERVICE
# ============================================================================
WORKER_PORT=3004
WORKER_CONCURRENCY=5
WORKER_QUEUE_NAME=wise2-jobs

# ============================================================================
# DISCORD BOT (Optional)
# ============================================================================
DISCORD_BOT_TOKEN=your-discord-bot-token-here
DISCORD_GUILD_ID=your-discord-guild-id
DISCORD_LOG_CHANNEL=your-discord-log-channel-id

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
# JWT Configuration
JWT_SECRET=dev-secret-key-change-in-production-minimum-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION=86400
JWT_REFRESH_EXPIRATION=604800

# Password Security
PASSWORD_MIN_LENGTH=12
PASSWORD_HASH_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Account Security
ACCOUNT_LOCKOUT_THRESHOLD=10
ACCOUNT_LOCKOUT_DURATION_MINUTES=60
SESSION_RETENTION_DAYS=30

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
# Prometheus Metrics
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15s

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE=/var/log/wise2/app.log
LOG_RETENTION_DAYS=30

# Sentry Error Tracking (Optional)
SENTRY_DSN=

# ============================================================================
# EXTERNAL SERVICES & AI
# ============================================================================
# Claude API (Primary AI Provider)
CLAUDE_API_KEY=sk-ant-...
CLAUDE_API_MODEL=claude-3-5-sonnet-20241022
CLAUDE_API_TIMEOUT=30000

# GitHub Integration (Optional)
GITHUB_TOKEN=ghp_...
GITHUB_OWNER=dwise03-bit
GITHUB_REPO=wise2-enterprise

# Stripe (Billing & Payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email Service (Resend or SendGrid)
EMAIL_SERVICE=resend
RESEND_API_KEY=re_...
SENDGRID_API_KEY=SG...

# YouTube API (LIVE Command Center)
YOUTUBE_API_KEY=AIza...

# Twitch API (LIVE Command Center)
TWITCH_CLIENT_ID=...
TWITCH_CLIENT_SECRET=...

# Discord API (Community Integration)
DISCORD_BOT_TOKEN=...
DISCORD_CLIENT_ID=...
DISCORD_CLIENT_SECRET=...

# ============================================================================
# STORAGE & BACKUP
# ============================================================================
# MinIO/S3 Configuration
STORAGE_TYPE=s3
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=wise2-backups
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30

# ============================================================================
# OLLAMA (Local LLM - Optional)
# ============================================================================
OLLAMA_ENABLED=false
OLLAMA_API_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ============================================================================
# FEATURE FLAGS
# ============================================================================
FEATURE_AUTOMATION_ENABLED=true
FEATURE_API_DOCS_ENABLED=true
FEATURE_METRICS_ENABLED=true
FEATURE_AUDIT_LOGGING_ENABLED=true

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================
# Mock External Services (for testing without API keys)
MOCK_EXTERNAL_SERVICES=false

# Verbose Logging for Debugging
DEBUG=wise2:*

# Disable Authentication (development only!)
DISABLE_AUTH=false

# ============================================================================
# TESTING
# ============================================================================
TEST_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wise2_test
TEST_REDIS_URL=redis://localhost:6379/1
TEST_TIMEOUT=30000

# ============================================================================
# IMPORTANT SECURITY REMINDERS
# ============================================================================
# 1. NEVER commit .env to Git (add to .gitignore)
# 2. Use strong, random passwords for all services
# 3. Rotate API keys regularly
# 4. Use different secrets for each environment
# 5. Restrict .env file permissions: chmod 600 .env
# 6. Store production secrets in secure vault
# Generate JWT_SECRET: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================================================
