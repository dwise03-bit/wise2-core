# API Configuration
NODE_ENV=development
API_HOST=localhost
API_PORT=3001
API_LOG_LEVEL=info

# Database (PostgreSQL - Podcast Music, existing features)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wise2_core
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=wise2_core

# Database (MongoDB - Brain features)
MONGODB_URI=mongodb://localhost:27017/wise2-brain

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=dev-password
REDIS_DB=0

# Security
JWT_SECRET=change-me-in-production
JWT_EXPIRATION=86400
JWT_REFRESH_EXPIRATION=604800

# CORS
API_CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Logging
LOG_LEVEL=info

# Google OAuth (Brain - Gmail & Drive integration)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/brain/auth/google/callback
APP_URL=http://localhost:3000

# Encryption (for storing OAuth tokens)
ENCRYPTION_KEY=your-32-byte-hex-key-openssl-rand-hex-32
