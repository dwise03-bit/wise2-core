# WISE² Production Environment Configuration
# Copy to .env.production and fill with real values

# APPLICATION
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# DATABASE (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=wise2_prod_user
DB_PASSWORD=CHANGE_ME_SECURE_PASSWORD
DB_NAME=wise2_core_prod
DATABASE_URL=postgresql://wise2_prod_user:CHANGE_ME_SECURE_PASSWORD@postgres:5432/wise2_core_prod

# CACHE (Redis)
REDIS_URL=redis://redis:6379
REDIS_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# SECURITY
JWT_SECRET=CHANGE_ME_SECURE_RANDOM_STRING_32_CHARS_MINIMUM
JWT_EXPIRATION=86400

# API
NEXT_PUBLIC_API_URL=https://api.wise2.net
CORS_ORIGIN=https://wise2.net,https://dashboard.wise2.net,https://admin.wise2.net,https://studio.wise2.net

# STRIPE PAYMENTS
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME

# OAUTH
GOOGLE_CLIENT_ID=CHANGE_ME.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=CHANGE_ME
GITHUB_CLIENT_ID=CHANGE_ME
GITHUB_CLIENT_SECRET=CHANGE_ME

# EMAIL (SendGrid)
SENDGRID_API_KEY=SG.CHANGE_ME
SENDGRID_FROM_EMAIL=noreply@wise2.net

# ANALYTICS
POSTHOG_API_KEY=CHANGE_ME

# MONITORING
GRAFANA_ADMIN_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_SECURE_PASSWORD

# FEATURES
ENABLE_SOUNDLABS=true
ENABLE_LIVE_STREAMING=true
ENABLE_AI_AUTOMATIONS=true
ENABLE_PAYMENTS=true
ENABLE_OAUTH=true
