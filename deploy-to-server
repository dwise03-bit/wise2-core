#!/bin/bash
set -e

REMOTE_USER="dwise"
REMOTE_HOST="wise2.net"

echo "🚀 Deploying WISE² Website to wise2.net"
echo "========================================"

# Push code
echo "📤 Pushing to GitHub..."
git add -A
git commit -m "Deploy: Website update" || true
git push origin main

# Deploy on server
echo "📡 Deploying to wise2.net..."
ssh "$REMOTE_USER@$REMOTE_HOST" << 'REMOTE'
cd /home/dwise/wise2-core
echo "📥 Pulling latest code..."
git pull origin main

echo "🐳 Building Docker image..."
docker build -f apps/website/Dockerfile -t wise2-website:latest .

echo "🚀 Starting container..."
cd apps/website
docker-compose up -d

sleep 3
echo ""
echo "✅ DEPLOYMENT COMPLETE"
echo "🌐 Website: https://wise2.net"
REMOTE

echo ""
echo "✅ Deployment successful!"
