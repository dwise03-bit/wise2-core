#!/bin/bash
set -e

REMOTE_USER="dwise"
REMOTE_HOST="wise2.net"

echo "🚀 Deploying to wise2.net..."

ssh "$REMOTE_USER@$REMOTE_HOST" << 'REMOTE'
cd /home/dwise/wise2-core

# Sync with GitHub (force update, discard any conflicts)
git fetch origin
git reset --hard origin/main

# Deploy (build and start via docker-compose)
echo "Building and deploying..."
cd apps/website
docker-compose down 2>/dev/null || true
docker-compose up -d --build

sleep 5
echo "✅ DEPLOYED"
curl http://localhost:3000 | head -5
REMOTE
