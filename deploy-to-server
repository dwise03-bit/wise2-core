#!/bin/bash
set -e

REMOTE_USER="dwise"
REMOTE_HOST="wise2.net"

echo "🚀 Deploying to wise2.net..."

ssh "$REMOTE_USER@$REMOTE_HOST" << 'REMOTE'
cd /home/dwise/wise2-core

# Sync with GitHub (force update, discard any conflicts)
git fetch origin
git reset --hard origin/main

# Remove old container/image
docker-compose -f apps/website/docker-compose.yml down 2>/dev/null || true
docker rmi wise2-website:latest 2>/dev/null || true

# Build
echo "Building..."
docker build -f apps/website/Dockerfile -t wise2-website:latest .

# Deploy
echo "Deploying..."
cd apps/website
docker-compose up -d

sleep 5
echo "✅ DEPLOYED"
curl http://localhost:3000 | head -5
REMOTE
