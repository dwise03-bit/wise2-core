# Database
DATABASE_URL="postgresql://user:password@localhost:5432/podcast_music_dev"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Stripe (Test Mode - Use Test Keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_51234567890abc"
STRIPE_SECRET_KEY="sk_test_1234567890abc"
STRIPE_WEBHOOK_SECRET="whsec_1234567890abc"

# Stripe Product Configuration (non-secret IDs; safe as defaults)
STRIPE_PRICE_ID_MONTHLY="price_1TuZOAKBHbhfqNRY3qpEh0CZ"
STRIPE_PRODUCT_ID="prod_UuOAPvJPcKaPGJ"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3003"
NODE_ENV="development"

# AI Audio Provider (for /generate endpoint)
# AUDIO_PROVIDER: "mock" (default, no keys needed), "suno", or "auto"
#   auto -> uses suno if SUNO_API_KEY is set, otherwise falls back to mock
AUDIO_PROVIDER="mock"
SUNO_API_KEY=""
SUNO_API_BASE_URL="https://api.suno.ai/v1"

# AI Job Queue (optional; for background processing at scale)
REDIS_URL="redis://localhost:6379"
OPENAI_API_KEY="sk-your-openai-key"

# File Storage
STORAGE_BUCKET_NAME="podcast-music-files"
STORAGE_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret"

# Logging
LOG_LEVEL="debug"

# Email (for notifications)
SENDGRID_API_KEY="SG.your-sendgrid-key"
SUPPORT_EMAIL="support@wise2.com"
