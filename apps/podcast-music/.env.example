# Database
DATABASE_URL="postgresql://user:password@localhost:5432/podcast_music_dev"

# JWT Authentication
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Stripe (Test Mode - Use Test Keys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_51234567890abc"
STRIPE_SECRET_KEY="sk_test_1234567890abc"
STRIPE_WEBHOOK_SECRET="whsec_1234567890abc"

# Stripe Product Configuration
STRIPE_PRICE_ID_MONTHLY="price_1234567890abc"
STRIPE_PRODUCT_ID="prod_1234567890abc"

# App Configuration
NEXT_PUBLIC_APP_URL="http://localhost:3003"
NODE_ENV="development"

# AI Job Queue (for /generate endpoint)
REDIS_URL="redis://localhost:6379"
OPENAI_API_KEY="sk-your-openai-key"

# File Storage
STORAGE_BUCKET_NAME="podcast-music-files"
STORAGE_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-aws-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret"

# Logging
LOG_LEVEL="debug"

# Email (for notifications)
SENDGRID_API_KEY="SG.your-sendgrid-key"
SUPPORT_EMAIL="support@wise2.com"
