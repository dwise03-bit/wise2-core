# WISE² Website Environment Configuration
#
# Copy this file to .env.local (development) or .env.production (production)
# and fill in the values for your environment.

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Site URL - Used for redirects, links, and API calls
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# API Base URL - Backend API endpoint
NEXT_PUBLIC_API_URL=http://localhost:3000

# ============================================================================
# ANALYTICS
# ============================================================================

# Google Analytics 4 Measurement ID
# Get from: https://analytics.google.com/
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_ANALYTICS_ID=G-LOCALHOST

# ============================================================================
# STRIPE PAYMENT CONFIGURATION
# ============================================================================

# Stripe Publishable Key (Public - safe in client-side code)
# Get from: https://dashboard.stripe.com/apikeys
# Test key starts with: pk_test_
# Live key starts with: pk_live_
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Price IDs for subscription plans
# Get from: https://dashboard.stripe.com/products
# These are the Stripe Price IDs for your pricing tiers
NEXT_PUBLIC_STRIPE_STARTER_PRICE_ID=price_starter_id_here
NEXT_PUBLIC_STRIPE_PROFESSIONAL_PRICE_ID=price_professional_id_here
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_id_here

# ============================================================================
# DISCORD INTEGRATION
# ============================================================================

# Discord Webhook URL for notifications
# Get from: Discord Server Settings > Integrations > Webhooks > New Webhook
# Used for: Alerts, notifications, activity logging
# Format: https://discord.com/api/webhooks/[WEBHOOK_ID]/[WEBHOOK_TOKEN]
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your_webhook_id/your_webhook_token

# ============================================================================
# YOUTUBE INTEGRATION
# ============================================================================

# YouTube Channel ID
# Get from: https://www.youtube.com/account/advanced_account
# Format: UC (followed by alphanumeric characters)
NEXT_PUBLIC_YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxx

# YouTube API Key (for fetching channel data, latest videos, etc.)
# Get from: https://console.cloud.google.com/apis/credentials
# - Create a new API Key
# - Enable YouTube Data API v3
# - Restrict to HTTP referrers (your domain)
# Format: AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_YOUTUBE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# STRIPE SERVER-SIDE CONFIGURATION (Secret Keys - Server Only)
# ============================================================================

# Stripe Secret Key (Server-side only - NEVER expose in client code)
# Get from: https://dashboard.stripe.com/apikeys
# Test key starts with: sk_test_
# Live key starts with: sk_live_
# NOTE: This should only be in environment variables, never in .env files
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe Webhook Secret (for verifying webhook signatures)
# Get from: https://dashboard.stripe.com/webhooks
# Find your endpoint, click "Reveal" next to Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================================================
# HERMES/AI CONFIGURATION (Optional - for AI chat features)
# ============================================================================

# Hermes/Ollama endpoint for local LLM inference
# Used by: /api/chat route for AI responses
# Default: http://localhost:11434/v1/chat/completions (Ollama)
# Format: http://[host]:[port]/[endpoint]
HERMES_ENDPOINT=http://localhost:11434/v1/chat/completions

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================

# Node environment (development, production, test)
NODE_ENV=development

# ============================================================================
# DEVELOPMENT NOTES
# ============================================================================
#
# .env.local - Used for local development
#   - Never commit to git
#   - Can use test/dummy values
#   - Applied automatically by Next.js
#
# .env.production - Used for production deployments
#   - Contains actual production values
#   - Should be managed via environment variables or secrets manager
#   - Never commit sensitive values
#
# .env.example - This file
#   - Safe to commit
#   - Documents all available configuration
#   - Shows format and where to obtain values
#
# ============================================================================
