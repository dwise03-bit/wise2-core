{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": ["eslint:recommended"],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "rules": {
    "prefer-const": "warn",
    "semi": ["error", "always"],
    "no-undef": "off",
    "no-unused-vars": "off"
  },
  "ignorePatterns": ["dist", "build", ".next"]
}
