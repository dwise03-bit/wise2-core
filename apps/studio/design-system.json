{
  "name": "WISE² Design System",
  "version": "1.0.0",
  "description": "Professional audio engineering UI system with neon/dark theme aesthetic",
  "brand": {
    "name": "WISE²",
    "primaryColor": "#0080FF",
    "accentColor": "#00D4FF",
    "style": "modern"
  },
  "colors": {
    "primary": {
      "50": "#e6f2ff",
      "100": "#b3d9ff",
      "200": "#80bfff",
      "300": "#4da6ff",
      "400": "#1a8cff",
      "500": "#0080ff",
      "600": "#0066cc",
      "700": "#004d99",
      "800": "#003366",
      "900": "#001a33"
    },
    "accent": {
      "50": "#e0f7ff",
      "100": "#b3eeff",
      "200": "#80e6ff",
      "300": "#4ddfff",
      "400": "#1ad7ff",
      "500": "#00d4ff",
      "600": "#00a8cc",
      "700": "#007c99",
      "800": "#005066",
      "900": "#002433"
    },
    "semantic": {
      "success": "#22c55e",
      "warning": "#fbbf24",
      "danger": "#ff3333",
      "info": "#00d4ff"
    },
    "neutral": {
      "50": "#f9fafb",
      "100": "#f3f4f6",
      "200": "#e5e7eb",
      "300": "#d1d5db",
      "400": "#9ca3af",
      "500": "#6b7280",
      "600": "#4b5563",
      "700": "#374151",
      "800": "#1f2937",
      "900": "#0f1419"
    }
  },
  "typography": {
    "fontFamily": {
      "sans": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "mono": "'Fira Code', 'Courier New', monospace"
    },
    "fontSize": {
      "xs": "0.625rem",
      "sm": "0.8125rem",
      "base": "1rem",
      "lg": "1.25rem",
      "xl": "1.5625rem",
      "2xl": "1.953125rem",
      "3xl": "2.44140625rem",
      "4xl": "3.0517578125rem",
      "5xl": "3.814697265625rem"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "lineHeight": {
      "tight": 1.2,
      "normal": 1.5,
      "relaxed": 1.75,
      "loose": 2
    }
  },
  "spacing": {
    "0": "0",
    "1": "0.25rem",
    "2": "0.5rem",
    "3": "0.75rem",
    "4": "1rem",
    "5": "1.25rem",
    "6": "1.5rem",
    "8": "2rem",
    "10": "2.5rem",
    "12": "3rem",
    "16": "4rem",
    "20": "5rem",
    "24": "6rem"
  },
  "sizing": {
    "touchTarget": "44px",
    "buttonHeightSm": "32px",
    "buttonHeightMd": "40px",
    "buttonHeightLg": "48px",
    "inputHeightSm": "32px",
    "inputHeightMd": "40px",
    "inputHeightLg": "48px"
  },
  "borders": {
    "radius": {
      "none": "0",
      "sm": "4px",
      "md": "8px",
      "lg": "12px",
      "xl": "16px",
      "full": "9999px"
    },
    "width": {
      "thin": "1px",
      "md": "2px",
      "thick": "3px"
    }
  },
  "shadows": {
    "sm": "0 1px 2px 0 rgba(0, 128, 255, 0.05)",
    "md": "0 4px 12px 0 rgba(0, 212, 255, 0.1)",
    "lg": "0 10px 24px 0 rgba(0, 128, 255, 0.15)",
    "xl": "0 20px 48px 0 rgba(0, 128, 255, 0.2)",
    "2xl": "0 25px 50px 0 rgba(0, 128, 255, 0.25)",
    "neon-sm": "0 0 10px rgba(0, 212, 255, 0.2)",
    "neon-md": "0 0 20px rgba(0, 212, 255, 0.3)",
    "neon-lg": "0 0 40px rgba(0, 128, 255, 0.4)"
  },
  "animation": {
    "duration": {
      "fast": "150ms",
      "base": "200ms",
      "slow": "300ms",
      "slower": "500ms"
    },
    "easing": {
      "in": "cubic-bezier(0.4, 0, 1, 1)",
      "out": "cubic-bezier(0, 0, 0.2, 1)",
      "in-out": "cubic-bezier(0.4, 0, 0.2, 1)",
      "linear": "linear"
    }
  },
  "breakpoints": {
    "xs": "0",
    "sm": "480px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },
  "components": {
    "Button": {
      "variants": ["primary", "secondary", "danger", "ghost"],
      "sizes": ["sm", "md", "lg"],
      "states": ["default", "hover", "active", "focus", "disabled"]
    },
    "Input": {
      "variants": ["default", "error", "success"],
      "sizes": ["sm", "md", "lg"]
    },
    "Meter": {
      "sizes": ["compact", "normal", "large"],
      "zones": ["safe", "caution", "critical"]
    },
    "Chat": {
      "features": ["emoji picker", "message filtering", "moderation controls", "user badges"]
    },
    "Mixer": {
      "channels": ["MIC 1", "MIC 2", "INSTR 1", "INSTR 2", "BEAT", "PLAYBACK", "MASTER"],
      "controls": ["volume fader", "VU meter", "mute button", "solo button", "peak hold"]
    }
  },
  "accessibility": {
    "wcagLevel": "AA",
    "contrastRatios": {
      "normalText": "4.5:1",
      "largeText": "3:1"
    },
    "focusIndicator": {
      "color": "#00d4ff",
      "width": "2px",
      "offset": "2px"
    },
    "touchTarget": {
      "minSize": "44px",
      "minSpacing": "8px"
    }
  },
  "usage": {
    "cssVariables": "Use var(--color-primary-500) syntax in CSS",
    "tailwind": "Configure theme extension in tailwind.config.js",
    "react": "Import design-tokens.css in globals.css or _app.tsx",
    "typescript": "Use design-system.json for type definitions",
    "figma": "Import via Tokens Studio plugin for design sync"
  }
}
