# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Google OAuth Configuration
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here

# Stripe Configuration
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe Product IDs (create these in Stripe Dashboard)
NEXT_PUBLIC_STRIPE_FREE_PRODUCT_ID=prod_free_tier
NEXT_PUBLIC_STRIPE_PRO_PRODUCT_ID=prod_pro_tier
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRODUCT_ID=prod_enterprise_tier

# Stripe Price IDs (create these in Stripe Dashboard)
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_pro_monthly
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=price_enterprise_monthly

# Stripe Success/Cancel URLs
NEXT_PUBLIC_STRIPE_SUCCESS_URL=http://localhost:3003/subscription/success
NEXT_PUBLIC_STRIPE_CANCEL_URL=http://localhost:3003/subscription/cancel
