# WISE² Discord Ecosystem - Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# GUILD CONFIGURATION
# ============================================================================

# Target Discord server ID (optional, for guild-specific commands)
GUILD_ID=

# ============================================================================
# EXECUTIVE BOT
# ============================================================================

# Bot token (obtain from Discord Developer Portal)
EXECUTIVE_BOT_TOKEN=

# Application client ID
EXECUTIVE_CLIENT_ID=

# ============================================================================
# DEPLOYMENT BOT
# ============================================================================

DEPLOYMENT_BOT_TOKEN=
DEPLOYMENT_CLIENT_ID=

# Deployment configuration
DEPLOYMENT_STAGING_WEBHOOK=
DEPLOYMENT_PRODUCTION_WEBHOOK=

# ============================================================================
# NOTIFICATION BOT
# ============================================================================

NOTIFICATION_BOT_TOKEN=
NOTIFICATION_CLIENT_ID=

# Notification channels
NOTIFICATION_CHANNEL_ID=
ALERT_CHANNEL_ID=

# ============================================================================
# AUTOMATION BOT
# ============================================================================

AUTOMATION_BOT_TOKEN=
AUTOMATION_CLIENT_ID=

# Webhook configuration
AUTOMATION_WEBHOOK_SECRET=

# ============================================================================
# STATUS BOT
# ============================================================================

STATUS_BOT_TOKEN=
STATUS_CLIENT_ID=

# Status page URL
STATUS_PAGE_URL=

# Health check endpoints (comma-separated)
HEALTH_CHECK_ENDPOINTS=http://localhost:3000/health,http://localhost:5432/health

# Raspberry Pi monitoring
RASPBERRY_PI_HOSTS=192.168.1.100,192.168.1.101
RASPBERRY_PI_USERNAME=pi
RASPBERRY_PI_PASSWORD=

# ============================================================================
# ANALYTICS BOT
# ============================================================================

ANALYTICS_BOT_TOKEN=
ANALYTICS_CLIENT_ID=

# Metrics service
METRICS_ENDPOINT=http://localhost:9090
METRICS_API_KEY=

# Grafana integration
GRAFANA_URL=http://localhost:3000
GRAFANA_API_KEY=

# ============================================================================
# KNOWLEDGE BOT
# ============================================================================

KNOWLEDGE_BOT_TOKEN=
KNOWLEDGE_CLIENT_ID=

# Knowledge base URL
KNOWLEDGE_BASE_URL=http://localhost:8000

# Elasticsearch configuration
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ============================================================================
# VOICE BOT
# ============================================================================

VOICE_BOT_TOKEN=
VOICE_CLIENT_ID=

# Voice service providers
GOOGLE_CLOUD_API_KEY=
DEEPGRAM_API_KEY=

# Voice assistant settings
VOICE_LANGUAGE=en-US
VOICE_SAMPLE_RATE=16000

# ============================================================================
# EMERGENCY BOT
# ============================================================================

EMERGENCY_BOT_TOKEN=
EMERGENCY_CLIENT_ID=

# Escalation settings
ESCALATION_CHANNEL_ID=
PAGERDUTY_API_KEY=
OPSGENIE_API_KEY=

# On-call settings
ON_CALL_WEBHOOK=
ON_CALL_SCHEDULE_ID=

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: debug, info, warn, error, fatal
LOG_LEVEL=info

# Log directory
LOG_DIR=./logs

# Log retention (days)
LOG_RETENTION_DAYS=30

# ============================================================================
# MESSAGE QUEUE CONFIGURATION
# ============================================================================

# Queue directory
QUEUE_DIR=./queue

# Queue processing interval (ms)
QUEUE_INTERVAL=10000

# Max retries for failed messages
QUEUE_MAX_RETRIES=3

# ============================================================================
# RATE LIMITING
# ============================================================================

# User rate limit (requests per minute)
RATE_LIMIT_USER=10

# Guild rate limit (requests per minute)
RATE_LIMIT_GUILD=20

# Channel rate limit (requests per minute)
RATE_LIMIT_CHANNEL=30

# Command rate limit (requests per minute)
RATE_LIMIT_COMMAND=5

# ============================================================================
# CACHE CONFIGURATION
# ============================================================================

# Cache TTL (milliseconds)
CACHE_TTL=60000

# Cache max size
CACHE_MAX_SIZE=1000

# Cache strategy: lru, lfu, fifo
CACHE_STRATEGY=lru

# ============================================================================
# AUDIT LOGGING
# ============================================================================

# Enable audit logging
AUDIT_ENABLED=true

# Audit log channels (comma-separated)
AUDIT_CHANNELS=

# Audit log file
AUDIT_LOG_FILE=./audit/audit.jsonl

# Audit retention (days)
AUDIT_RETENTION_DAYS=90

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# PostgreSQL connection
DATABASE_URL=postgresql://user:password@localhost:5432/wise2_discord

# Redis connection
REDIS_URL=redis://localhost:6379

# ============================================================================
# API CONFIGURATION
# ============================================================================

# API base URL
API_BASE_URL=http://localhost:3000

# API timeout (ms)
API_TIMEOUT=30000

# API rate limit
API_RATE_LIMIT=100

# ============================================================================
# ENVIRONMENT
# ============================================================================

# Node environment
NODE_ENV=development

# Application name
APP_NAME=WISE² Discord Ecosystem

# Version
APP_VERSION=1.0.0

# ============================================================================
# MONITORING & ALERTING
# ============================================================================

# Sentry DSN for error tracking
SENTRY_DSN=

# Datadog API key
DATADOG_API_KEY=

# Alert webhook (Slack, Teams, etc.)
ALERT_WEBHOOK_URL=

# ============================================================================
# FEATURE FLAGS
# ============================================================================

# Enable/disable specific features
FEATURE_VOICE_ENABLED=true
FEATURE_AUTOMATION_ENABLED=true
FEATURE_ANALYTICS_ENABLED=true
FEATURE_EMERGENCY_ENABLED=true

# ============================================================================
# ADVANCED CONFIGURATION
# ============================================================================

# Max concurrent connections
MAX_CONNECTIONS=100

# Command prefix (for text commands, if supported)
COMMAND_PREFIX=!

# Enable debug mode
DEBUG=false

# Custom emoji URLs
EMOJI_SUCCESS=
EMOJI_ERROR=
EMOJI_WARNING=
EMOJI_INFO=
