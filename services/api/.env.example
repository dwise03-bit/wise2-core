# ============================================================================
# WISE² API Service Environment Variables
# ============================================================================

# Application Configuration
NODE_ENV=development
API_PORT=3000
API_HOST=0.0.0.0
API_LOG_LEVEL=info

# Database Configuration
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wise2_core
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=wise2_core
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis Configuration (for sessions, caching, jobs)
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-32-chars-min
JWT_EXPIRATION=86400
JWT_REFRESH_EXPIRATION=604800

# CORS Configuration
API_CORS_ORIGIN=http://localhost:3001,https://wise2.net

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Stripe Configuration (for payments)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# AWS Configuration (for S3 file storage)
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=wise2-files
AWS_CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# Discord Configuration (for OAuth)
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_client_id
DISCORD_CLIENT_SECRET=your_discord_client_secret

# Sentry Configuration (for error tracking)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Email Configuration (for notifications)
SENDGRID_API_KEY=your_sendgrid_api_key
EMAIL_FROM_ADDRESS=noreply@wise2.net
