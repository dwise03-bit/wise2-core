# WISE² Paperclip configuration
# Copy to .env and fill in. Run `./paperclip.sh env` after onboarding for the
# authoritative, version-accurate variable list.

# --- Database ---------------------------------------------------------------
# Leave DATABASE_URL empty to use the bundled embedded-postgres (onboard sets
# up a local cluster automatically). Set it to point at an external Postgres.
DATABASE_URL=

# --- Server -----------------------------------------------------------------
PAPERCLIP_PORT=4400
PAPERCLIP_HOST=127.0.0.1

# --- Model providers (model-agnostic; set the ones you use) -----------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Governance defaults ----------------------------------------------------
# Default monthly spend ceiling per agent, in USD. Agents auto-pause at limit.
PAPERCLIP_DEFAULT_AGENT_BUDGET_USD=50
