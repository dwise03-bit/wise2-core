{
  "name": "@wise2/edge-appliance",
  "version": "1.0.0",
  "description": "Raspberry Pi WISE² Edge Appliance - Local AI inference, voice control, GPIO automation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "type-check": "tsc --noEmit",
    "docker:build": "docker build -f docker/Dockerfile -t wise2/edge-appliance:latest .",
    "docker:run": "docker-compose -f docker-compose.yml up -d",
    "docker:stop": "docker-compose -f docker-compose.yml down"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "better-sqlite3": "^9.0.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.2.0",
    "node-cron": "^3.0.2",
    "pino": "^8.16.1",
    "sqlite-crdt": "^0.1.0",
    "uuid": "^9.0.1",
    "wireguard": "^2.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.10",
    "@types/node": "^20.19.43",
    "@types/node-cron": "^3.0.8",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "ts-jest": "^29.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
