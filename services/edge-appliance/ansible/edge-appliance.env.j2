# WISE² Edge Appliance Environment Configuration
# Generated by Ansible

# Runtime
NODE_ENV=production
NODE_ID={{ node_id }}
PORT=3000
LOG_LEVEL=info

# Database
LOCAL_DB_PATH={{ wise2_home }}/data/wise2-edge.db

# AI Models
MODEL_PATH={{ wise2_home }}/models
VOICE_MODEL=mistral

# Cloud Configuration
CLOUD_URL={{ cloud_url }}
API_KEY={{ api_key }}

# Network
WIREGUARD_CONFIG_PATH=/etc/wireguard/wise2.conf

# Feature Flags
OFFLINE_MODE=false
ENABLE_VOICE=true
ENABLE_GPIO=true
ENABLE_CAMERA=true

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Security
JWT_SECRET={{ vault_jwt_secret | default('change-me-in-production') }}
TLS_ENABLED=false
TLS_CERT_PATH=/etc/wise2/tls/cert.pem
TLS_KEY_PATH=/etc/wise2/tls/key.pem

# Performance
MAX_CONNECTIONS=100
REQUEST_TIMEOUT=30000
SYNC_INTERVAL=30000

# Monitoring
HEALTH_CHECK_INTERVAL=30000
METRICS_RETENTION_HOURS=168
ENABLE_PROMETHEUS=false
PROMETHEUS_PORT=9090
