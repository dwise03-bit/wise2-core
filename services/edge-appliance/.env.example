# WISE² Edge Appliance Configuration
# Copy this file to .env and configure for your deployment

# ==========================
# Runtime Configuration
# ==========================
NODE_ENV=production              # development, testing, or production
NODE_ID=edge-node-1              # Unique identifier for this edge node
PORT=3000                         # API server port
LOG_LEVEL=info                    # Logging level: debug, info, warn, error

# ==========================
# Database & Storage
# ==========================
LOCAL_DB_PATH=/data/wise2-edge.db # Path to SQLite database
MODEL_PATH=/models                # Path to AI models directory

# ==========================
# Cloud Configuration
# ==========================
CLOUD_URL=https://api.wise2.cloud # Cloud API endpoint
API_KEY=                          # API authentication key (set via secrets management)

# ==========================
# AI Models
# ==========================
VOICE_MODEL=mistral              # Ollama model name for voice/agent
OLLAMA_URL=http://localhost:11434 # Ollama API endpoint

# ==========================
# Network & VPN
# ==========================
WIREGUARD_CONFIG_PATH=/etc/wireguard/wise2.conf  # WireGuard configuration
OFFLINE_MODE=false               # Disable cloud connectivity

# ==========================
# Feature Flags
# ==========================
ENABLE_VOICE=true                # Enable voice control
ENABLE_GPIO=true                 # Enable GPIO automation
ENABLE_CAMERA=true               # Enable camera access

# ==========================
# Performance Tuning
# ==========================
MAX_CONNECTIONS=100              # Maximum concurrent connections
REQUEST_TIMEOUT=30000            # Request timeout in milliseconds
SYNC_INTERVAL=30000              # Cloud sync interval in milliseconds
HEALTH_CHECK_INTERVAL=30000      # Health check interval in milliseconds

# ==========================
# Security
# ==========================
JWT_SECRET=                       # JWT signing secret (generate with `openssl rand -hex 32`)
TLS_ENABLED=false                # Enable TLS/HTTPS
TLS_CERT_PATH=/etc/wise2/tls/cert.pem  # TLS certificate path
TLS_KEY_PATH=/etc/wise2/tls/key.pem    # TLS key path

# ==========================
# Monitoring
# ==========================
ENABLE_PROMETHEUS=false          # Enable Prometheus metrics
PROMETHEUS_PORT=9090             # Prometheus port
METRICS_RETENTION_HOURS=168      # Metrics retention (hours)

# ==========================
# Development/Debug (not for production)
# ==========================
DEBUG=                           # Debug namespace pattern
VERBOSE=false                    # Verbose logging
MOCK_HARDWARE=false              # Use mock hardware (for non-Pi testing)
