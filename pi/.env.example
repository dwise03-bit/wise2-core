# WISE² Raspberry Pi Environment Configuration
# Copy this to .env and fill in values

# ============================================================================
# Core Configuration
# ============================================================================

NODE_ENV=production
ENVIRONMENT=pi
APP_NAME="WISE² Enterprise"
APP_VERSION="1.0.0-pi"
LOG_LEVEL=info

# ============================================================================
# Security & Secrets
# ============================================================================

# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32

# Generate with: openssl rand -hex 32
API_KEY=change_me_generate_with_openssl_rand_hex_32

# Generate with: openssl rand -hex 16
REDIS_PASSWORD=change_me_generate_with_openssl_rand_hex_16

# Grafana admin password (if monitoring enabled)
GRAFANA_PASSWORD=admin

# ============================================================================
# Database Configuration
# ============================================================================

# SQLite (embedded, no external database needed)
# Database file location: /data/wise2.db
DATABASE_URL="file:/data/wise2.db"
DB_TYPE="sqlite"

# ============================================================================
# Redis Configuration
# ============================================================================

REDIS_URL="redis://:${REDIS_PASSWORD}@redis:6379"
REDIS_PORT=6379
REDIS_MAX_MEMORY=256mb

# ============================================================================
# Server Configuration
# ============================================================================

PORT=3000
HOST="0.0.0.0"

# ============================================================================
# AI Configuration (Ollama)
# ============================================================================

# Enable AI features (set to false on low-memory systems)
OLLAMA_ENABLED=false

# Ollama server URL
OLLAMA_URL="http://ollama:11434"

# Model to use (lightweight options for Pi)
# Options: qwen2.5:1.5b, phi3:mini, tinyllama
OLLAMA_MODEL="qwen2.5:1.5b"

# ============================================================================
# Networking
# ============================================================================

# mDNS hostname (will be accessible at wise.local)
HOSTNAME=wise

# Enable mDNS discovery
MDNS_ENABLED=true

# ============================================================================
# Backup Configuration
# ============================================================================

# Backup directory
BACKUP_DIR=/backups

# Backup schedule (cron format)
BACKUP_SCHEDULE="0 2 * * *"  # Daily at 2 AM

# Keep last N backups
BACKUP_RETENTION=7

# ============================================================================
# Demo Data
# ============================================================================

# Load demo data on first start
LOAD_DEMO_DATA=true

# Demo businesses to load (comma-separated)
DEMO_BUSINESSES="coffee-shop,hvac-company,tattoo-studio,church,restaurant,auto-repair,gym"

# ============================================================================
# Monitoring (Optional)
# ============================================================================

# Enable Prometheus monitoring
PROMETHEUS_ENABLED=false

# Enable Grafana dashboards
GRAFANA_ENABLED=false

# ============================================================================
# Development (Not used in production)
# ============================================================================

DEBUG=false
VERBOSE_LOGGING=false
